{
  "name": "brothers-trans-marketing-dashboard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @brothers-trans/web",
    "build": "npm run build --workspace @brothers-trans/web",
    "lint": "npm run lint --workspace @brothers-trans/web",
    "typecheck": "npm run typecheck --workspace @brothers-trans/web",
    "db:generate": "prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/database/prisma/schema.prisma",
    "db:seed": "node packages/database/scripts/seed.cjs",
    "postinstall": "npm run db:generate",
    "db:deploy": "prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
